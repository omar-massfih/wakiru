# No API key required for the default (codex) provider — auth is handled by the
# Codex CLI (`codex login`). All values below are optional; defaults used if unset.

# --- Storage backend ---
# local keeps markdown + SQLite under memory/. postgres uses Neon DATABASE_URL.
# STORAGE_BACKEND=postgres
# DATABASE_URL=postgres://...

# Which LLM backend to use: codex (default) | openai | anthropic.
# LLM_PROVIDER=codex

# API-backed providers only (openai / anthropic). Ignored by codex, which
# authenticates through the Codex CLI.
# LLM_API_KEY=sk-...
# Optional model override. Unset => a per-provider default (gpt-4o for openai,
# claude-opus-4-8 for anthropic).
# LLM_MODEL=
# Optional custom endpoint for an OpenAI-compatible API (openai provider only).
# LLM_BASE_URL=
# Request timeout (seconds) and reply-length cap (tokens) for the API-backed
# providers. The codex provider uses CODEX_TIMEOUT instead.
# LLM_TIMEOUT=120
# LLM_MAX_TOKENS=4096

# Path to the codex binary.
# CODEX_BIN=codex

# Model for Codex to use. Unset => Codex's own configured default.
# CODEX_MODEL=

# Sandbox for model-generated shell commands: read-only | workspace-write | danger-full-access
# CODEX_SANDBOX=read-only

# Working root for Codex. Unset => the server's current working directory.
# CODEX_WORKING_DIR=

# Hard wall-clock timeout (seconds) per Codex invocation.
# CODEX_TIMEOUT=300

# Enable Codex's native web search tool (live internet access). Off by default.
# CODEX_WEB_SEARCH=false

# HTTP server bind.
# HOST=127.0.0.1
# PORT=8000

# Bearer token required on every endpoint except /health (send it as
# "Authorization: Bearer <token>"). Unset => anyone who can reach the port is
# trusted — fine on loopback, but set this before exposing the server to a
# network (the Docker image binds 0.0.0.0).
#
# REQUIRED when running docker-compose.yml: it publishes 8000 on every
# interface, so without a token /memory (your personal notes), /calendar,
# /documents and /email are readable by anyone who can route to the host.
# Docker publishes ports via iptables, which bypasses a host ufw rule.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# API_TOKEN=
# Startup refuses a non-loopback bind without API_TOKEN. Set this only when a
# reverse proxy or VPN in front does the authentication instead.
# ALLOW_UNAUTHENTICATED=0

# --- Memory (the "brain") ---
# Directory for long-term memory notes + the SQLite index/checkpoints.
# MEMORY_DIR=memory
# Offline embedding model (fastembed/ONNX). Default is multilingual e5-large
# (1024-dim, ~2GB first-run download). For a lighter English-mostly setup try
# sentence-transformers/all-MiniLM-L6-v2.
# EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Notes recalled and injected per turn.
# RECALL_TOP_K=5
# Candidate-pool floor (cosine) and blended re-rank weights.
# RECALL_MIN_SIMILARITY=0.35
# RECALL_W_SIMILARITY=1.0
# RECALL_W_RECENCY=0.15
# RECALL_W_REUSE=0.15
# RECALL_W_SALIENCE=0.1
# Master switch for automatic save/update/forget after each turn.
# ENABLE_AUTO_MEMORY=true
# Personalization: inject notes tagged "profile" (working hours, locations,
# quiet hours, tone) every turn, and hold reminders/briefing during stated
# quiet hours. No-op until such notes exist.
# ENABLE_PROFILE=true
# Per-kind cap on index entries injected into the prompt each turn (JSON;
# -1 = unlimited, 0 = omit the kind). MEMORY.md on disk is never trimmed.
# CONTEXT_INDEX_MAX_PER_KIND={"semantic": 20, "procedural": 10, "episodic": 2}
# Dedup: candidate pool size and the cross-kind (semantic<->procedural) threshold.
# DEDUP_CANDIDATES=10
# DEDUP_CROSS_KIND_THRESHOLD=0.95
# Fuzzy forget: similarity floor and the no-op margin when two matches are close.
# FORGET_THRESHOLD=0.88
# FORGET_AMBIGUITY_MARGIN=0.03
# Skip the per-turn episodic trace for short messages / near-duplicate exchanges.
# EPISODIC_MIN_CHARS=12
# EPISODIC_DEDUP_THRESHOLD=0.97
# Consolidation ("sleep"): run every N turns (0 disables); episodic retention.
# CONSOLIDATE_EVERY_N_TURNS=20
# EPISODIC_MAX_AGE_DAYS=30
# Hard per-kind note caps enforced during consolidation (JSON; 0 = uncapped).
# MAX_NOTES_PER_KIND={"semantic": 200, "procedural": 100, "episodic": 200}
# Half-life (days) for salience decay of never-recalled durable notes (0 disables).
# DURABLE_DECAY_HALF_LIFE_DAYS=180
# Working memory: summarize+trim history past this many messages (0 disables).
# WORKING_MEMORY_MAX_MESSAGES=40
# WORKING_MEMORY_KEEP_RECENT=12

# --- Time & calendar ---
# IANA timezone the assistant reasons in (e.g. Europe/Oslo). Unset => system-local.
# TIMEZONE=
# Inject current time + upcoming events into each turn.
# ENABLE_CALENDAR=true
# How far ahead (days) upcoming events are surfaced, and the per-turn cap.
# CALENDAR_UPCOMING_DAYS=14
# CALENDAR_MAX_EVENTS=20
# ICS subscription URLs mirrored (read-only) into the local calendar — Google's
# "secret iCal address" (Settings > your calendar > Integrate), Outlook, etc.
# JSON list. Synced events show up in the agenda, conflicts, and reminders, but
# must be changed in the source calendar.
# CALENDAR_ICS_URLS=["https://calendar.google.com/calendar/ical/…/basic.ics"]
# Minutes between pulls. 0 disables the loop (POST /calendar/sync still works).
# CALENDAR_SYNC_MINUTES=15

# --- Voice notes (Telegram) ---
# Transcribe incoming Telegram voice messages locally (faster-whisper, offline
# after the first model download) and answer them like typed text.
# ENABLE_VOICE=true
# Whisper model size ("small" recommended for Norwegian + English).
# VOICE_MODEL=small
# Force a language code ("no", "en", …). Empty => autodetect per message.
# VOICE_LANGUAGE=
# Refuse clips longer than this many seconds.
# VOICE_MAX_SECONDS=600

# --- Slack channel ---
# Bot token (xoxb-…). Set => POST /slack/events accepts Events API callbacks.
# SLACK_BOT_TOKEN=
# Signing secret; every callback's HMAC is verified against it. Required with the token.
# SLACK_SIGNING_SECRET=
# App-level token (xapp-…) with connections:write. Set (with the bot token) =>
# events arrive over a Socket Mode websocket — no public HTTPS URL needed.
# SLACK_APP_TOKEN=
# Allowlist of Slack user ids the bot answers. EMPTY => it answers nobody
# (there is no pairing handshake, so this fails closed).
# SLACK_ALLOWED_USER_IDS=["U0123ABC"]
# Channel reminders and write-confirmations are pushed to. Unset => no push.
# SLACK_NOTIFY_CHANNEL=

# --- Email (opt-in; the only subsystem that talks to an external service) ---
# OFF by default. Nothing connects while this is false.
# ENABLE_EMAIL=false
# EMAIL_ADDRESS=you@gmail.com
# How to authenticate: oauth (XOAUTH2 refresh token) | password (app password).
# EMAIL_AUTH=oauth
# EMAIL_OAUTH_CLIENT_ID=
# EMAIL_OAUTH_CLIENT_SECRET=
# EMAIL_OAUTH_REFRESH_TOKEN=
# EMAIL_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
# App password, when EMAIL_AUTH=password.
# EMAIL_PASSWORD=
# IMAP/SMTP endpoints and the drafts mailbox (defaults are Gmail's).
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_DRAFTS_FOLDER=[Gmail]/Drafts
# EMAIL_MAX_MESSAGES=10
# Second, independent gate for actually SENDING. Drafting works without it; the
# assistant never sends in the background, only on an explicit request.
# ENABLE_EMAIL_SEND=false
# Minutes between background refreshes of the unread-mail snapshot injected
# into each turn (IMAP never runs on the reply path). 0 disables the block.
# EMAIL_SNAPSHOT_MINUTES=15

# --- Documents / notes ---
# Ingest documents and surface relevant chunks into recall each turn.
# ENABLE_DOCS=true
# How many chunks to inject per turn, and the cosine floor to inject at all.
# DOCS_RECALL_TOP_K=3
# DOCS_MIN_SIMILARITY=0.35
# Target chunk size (characters) at ingest time. Must be at least 1.
# DOCS_CHUNK_CHARS=800
# Allow POST /documents to ingest a URL (fetched server-side). Off by default:
# on a reachable server this is an SSRF primitive. Uploads (PDF/DOCX/text via
# POST /documents/upload) are always available while docs are enabled.
# ENABLE_DOCS_URL_INGEST=false
# Section size (characters) when summarizing a long document. A document larger
# than this is summarized section by section, then folded into one summary.
# DOCS_SUMMARIZE_CHARS=8000

# --- Tasks / to-dos ---
# Inject the open to-do list into each turn (read path).
# ENABLE_TASKS=true
# Cap on how many open tasks are injected per turn.
# TASKS_MAX_OPEN=20

# --- Proactive reminders ---
# Push a nudge ahead of upcoming events ("Dentist in 1 hour"). Off => no reminders.
# ENABLE_REMINDERS=true
# Minutes before an event to fire. JSON list; several leads => several nudges
# (e.g. [1440, 60] = a day before and an hour before). Default fires once, an hour out.
# REMINDER_LEAD_MINUTES=[60]
# ntfy topic URL / generic webhook the reminder is POSTed to. Unset => reminders are
# computed and returned by POST /reminders/run but not pushed anywhere.
# REMINDER_WEBHOOK_URL=https://ntfy.sh/your-private-topic
# How often the built-in ticker fires (seconds). 0 disables it (drive POST
# /reminders/run from external cron instead).
# REMINDER_TICK_SECONDS=60
# >0 => re-nudge every N minutes from the lead window until the event starts,
# instead of firing each lead once. Dated tasks also nag past their due time
# ("Task overdue: … (30 min ago)") until done. 0 keeps the one-shot behavior.
# REMINDER_REPEAT_MINUTES=15
# How long past its due time an overdue task keeps nagging (minutes). Only used
# when REMINDER_REPEAT_MINUTES > 0.
# REMINDER_OVERDUE_MAX_MINUTES=1440

# --- Daily briefing ---
# Push one digest per day (agenda + due tasks + unread mail when email is on)
# through the same channels reminders use. POST /briefing/run sends it on demand.
# ENABLE_BRIEFING=true
# Local wall-clock time (HH:MM, in TIMEZONE) the briefing becomes due; it fires
# on the first tick at/after this, exactly once per day.
# BRIEFING_TIME=07:30
# Rewrite the raw digest into a short morning note with one LLM call. false
# sends the assembled sections verbatim (no LLM cost).
# BRIEFING_LLM_POLISH=true

# --- Telegram channel ---
# Create a bot with @BotFather (/newbot) and paste its token to enable the channel.
# The first chat to message an unpaired bot is asked to echo back a pairing code
# printed in the server log; once paired it becomes the owner and every other chat
# is ignored. Un-pair by deleting memory/telegram_chats.json.
# TELEGRAM_BOT_TOKEN=
# Optional: pin/add chats explicitly (JSON list of ids), merged with the paired set.
# TELEGRAM_ALLOWED_CHAT_IDS=[123456789]
