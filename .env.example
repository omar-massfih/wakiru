# No API key required for the default (codex) provider — auth is handled by the
# Codex CLI (`codex login`). All values below are optional; defaults used if unset.

# Which LLM backend to use: codex (wired) | openai | anthropic (stubs — see llm.py).
# LLM_PROVIDER=codex

# Path to the codex binary.
# CODEX_BIN=codex

# Model for Codex to use. Unset => Codex's own configured default.
# CODEX_MODEL=

# Sandbox for model-generated shell commands: read-only | workspace-write | danger-full-access
# CODEX_SANDBOX=read-only

# Working root for Codex. Unset => the server's current working directory.
# CODEX_WORKING_DIR=

# Hard wall-clock timeout (seconds) per Codex invocation.
# CODEX_TIMEOUT=300

# Enable Codex's native web search tool (live internet access). Off by default.
# CODEX_WEB_SEARCH=false

# HTTP server bind.
# HOST=127.0.0.1
# PORT=8000

# Bearer token required on every endpoint except /health (send it as
# "Authorization: Bearer <token>"). Unset => anyone who can reach the port is
# trusted — fine on loopback, but set this before exposing the server to a
# network (the Docker image binds 0.0.0.0).
# API_TOKEN=

# --- Memory (the "brain") ---
# Directory for long-term memory notes + the SQLite index/checkpoints.
# MEMORY_DIR=memory
# Offline embedding model (fastembed/ONNX). Default is multilingual e5-large
# (1024-dim, ~2GB first-run download). For a lighter English-mostly setup try
# sentence-transformers/all-MiniLM-L6-v2.
# EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Notes recalled and injected per turn.
# RECALL_TOP_K=5
# Candidate-pool floor (cosine) and blended re-rank weights.
# RECALL_MIN_SIMILARITY=0.35
# RECALL_W_SIMILARITY=1.0
# RECALL_W_RECENCY=0.15
# RECALL_W_REUSE=0.15
# RECALL_W_SALIENCE=0.1
# Master switch for automatic save/update/forget after each turn.
# ENABLE_AUTO_MEMORY=true
# Per-kind cap on index entries injected into the prompt each turn (JSON;
# -1 = unlimited, 0 = omit the kind). MEMORY.md on disk is never trimmed.
# CONTEXT_INDEX_MAX_PER_KIND={"semantic": 20, "procedural": 10, "episodic": 0}
# Dedup: candidate pool size and the cross-kind (semantic<->procedural) threshold.
# DEDUP_CANDIDATES=10
# DEDUP_CROSS_KIND_THRESHOLD=0.95
# Fuzzy forget: similarity floor and the no-op margin when two matches are close.
# FORGET_THRESHOLD=0.88
# FORGET_AMBIGUITY_MARGIN=0.03
# Skip the per-turn episodic trace for short messages / near-duplicate exchanges.
# EPISODIC_MIN_CHARS=12
# EPISODIC_DEDUP_THRESHOLD=0.97
# Consolidation ("sleep"): run every N turns (0 disables); episodic retention.
# CONSOLIDATE_EVERY_N_TURNS=20
# EPISODIC_MAX_AGE_DAYS=30
# Hard per-kind note caps enforced during consolidation (JSON; 0 = uncapped).
# MAX_NOTES_PER_KIND={"semantic": 200, "procedural": 100, "episodic": 200}
# Half-life (days) for salience decay of never-recalled durable notes (0 disables).
# DURABLE_DECAY_HALF_LIFE_DAYS=180
# Working memory: summarize+trim history past this many messages (0 disables).
# WORKING_MEMORY_MAX_MESSAGES=40
# WORKING_MEMORY_KEEP_RECENT=12

# --- Time & calendar ---
# IANA timezone the assistant reasons in (e.g. Europe/Oslo). Unset => system-local.
# TIMEZONE=
# Inject current time + upcoming events into each turn.
# ENABLE_CALENDAR=true
# Master switch for automatic create/reschedule/cancel after each turn.
# ENABLE_AUTO_SCHEDULE=true
# How far ahead (days) upcoming events are surfaced, and the per-turn cap.
# CALENDAR_UPCOMING_DAYS=14
# CALENDAR_MAX_EVENTS=20

# --- Proactive reminders ---
# Push a nudge ahead of upcoming events ("Dentist in 1 hour"). Off => no reminders.
# ENABLE_REMINDERS=true
# Minutes before an event to fire. JSON list; several leads => several nudges
# (e.g. [1440, 60] = a day before and an hour before). Default fires once, an hour out.
# REMINDER_LEAD_MINUTES=[60]
# ntfy topic URL / generic webhook the reminder is POSTed to. Unset => reminders are
# computed and returned by POST /reminders/run but not pushed anywhere.
# REMINDER_WEBHOOK_URL=https://ntfy.sh/your-private-topic
# How often the built-in ticker fires (seconds). 0 disables it (drive POST
# /reminders/run from external cron instead).
# REMINDER_TICK_SECONDS=60

# --- Telegram channel ---
# Create a bot with @BotFather (/newbot) and paste its token to enable the channel.
# The first chat to message an unpaired bot is asked to echo back a pairing code
# printed in the server log; once paired it becomes the owner and every other chat
# is ignored. Un-pair by deleting memory/telegram_chats.json.
# TELEGRAM_BOT_TOKEN=
# Optional: pin/add chats explicitly (JSON list of ids), merged with the paired set.
# TELEGRAM_ALLOWED_CHAT_IDS=[123456789]
