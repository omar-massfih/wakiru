# No API key required for the default (codex) provider — auth is handled by the
# Codex CLI (`codex login`). All values below are optional; defaults used if unset.

# --- Storage backend ---
# local keeps markdown + SQLite under memory/. postgres uses Neon DATABASE_URL.
# STORAGE_BACKEND=postgres
# DATABASE_URL=postgres://...

# Which LLM backend to use: codex (default) | chatgpt | openai | anthropic.
# LLM_PROVIDER=codex

# API-backed providers only (openai / anthropic). Ignored by codex, which
# authenticates through the Codex CLI.
# LLM_API_KEY=sk-...
# Optional model override. Unset => a per-provider default (gpt-4o for openai,
# claude-opus-4-8 for anthropic).
# LLM_MODEL=
# Optional custom endpoint for an OpenAI-compatible API (openai provider only).
# LLM_BASE_URL=
# Request timeout (seconds) and reply-length cap (tokens) for the API-backed
# providers. The codex provider uses CODEX_TIMEOUT instead.
# LLM_TIMEOUT=120
# LLM_MAX_TOKENS=4096

# Path to the codex binary.
# CODEX_BIN=codex

# Model for Codex to use. Unset => Codex's own configured default.
# CODEX_MODEL=

# Sandbox for model-generated shell commands: read-only | workspace-write | danger-full-access
# CODEX_SANDBOX=read-only

# Working root for Codex. Unset => the server's current working directory.
# CODEX_WORKING_DIR=

# Hard wall-clock timeout (seconds) per Codex invocation.
# CODEX_TIMEOUT=300

# Enable Codex's native web search tool (live internet access). Off by default.
# CODEX_WEB_SEARCH=false

# --- ChatGPT backend (LLM_PROVIDER=chatgpt) ---
# Chats via chatgpt.com's backend using the OAuth tokens from `codex login`
# ($CODEX_HOME/auth.json). No API key; rate limits come from the ChatGPT plan.
# Must be a codex-supported model id, or chatgpt.com rejects it (HTTP 400).
# CHATGPT_MODEL=gpt-5.5
# Auth file override. Unset => $CODEX_HOME/auth.json or ~/.codex/auth.json.
# CHATGPT_AUTH_FILE=
# Socket timeout (seconds) per request/stream read.
# CHATGPT_TIMEOUT=300
# Max concurrent requests to chatgpt.com; excess calls queue.
# CHATGPT_MAX_CONCURRENCY=4

# --- Persona ---
# Voice register for replies: warm (default) | neutral | minimal. Unknown
# values fall back to warm.
# PERSONA_STYLE=warm

# HTTP server bind.
# HOST=127.0.0.1
# PORT=8000

# Bearer token required on every endpoint except /health (send it as
# "Authorization: Bearer <token>"). Unset => anyone who can reach the port is
# trusted — fine on loopback, but set this before exposing the server to a
# network (the Docker image binds 0.0.0.0).
#
# REQUIRED when running docker-compose.yml: it publishes 8000 on every
# interface, so without a token /memory (your personal notes), /calendar,
# /documents and /email are readable by anyone who can route to the host.
# Docker publishes ports via iptables, which bypasses a host ufw rule.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# API_TOKEN=
# Startup refuses a non-loopback bind without API_TOKEN. Set this only when a
# reverse proxy or VPN in front does the authentication instead.
# ALLOW_UNAUTHENTICATED=0

# --- Memory (the "brain") ---
# Directory for long-term memory notes + the SQLite index/checkpoints.
# MEMORY_DIR=memory
# Offline embedding model (fastembed/ONNX). Default is multilingual e5-large
# (1024-dim, ~2GB first-run download). For a lighter English-mostly setup try
# sentence-transformers/all-MiniLM-L6-v2.
# EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Notes recalled and injected per turn.
# RECALL_TOP_K=5
# Candidate-pool floor (cosine) and blended re-rank weights.
# RECALL_MIN_SIMILARITY=0.35
# RECALL_W_SIMILARITY=1.0
# RECALL_W_RECENCY=0.15
# RECALL_W_REUSE=0.15
# RECALL_W_SALIENCE=0.1
# Master switch for automatic save/update/forget after each turn.
# ENABLE_AUTO_MEMORY=true
# Personalization: inject notes tagged "profile" (working hours, locations,
# quiet hours, tone) every turn, and hold reminders/briefing during stated
# quiet hours. No-op until such notes exist.
# ENABLE_PROFILE=true
# Default quiet window (local time, HH:MM-HH:MM) used when no profile note
# states one. A stated preference in memory always wins; empty disables the
# default (no note => never quiet).
# QUIET_HOURS_DEFAULT=22:00-07:30
# Per-kind cap on index entries injected into the prompt each turn (JSON;
# -1 = unlimited, 0 = omit the kind). MEMORY.md on disk is never trimmed.
# CONTEXT_INDEX_MAX_PER_KIND={"semantic": 20, "procedural": 10, "episodic": 2}
# Dedup: candidate pool size and the cross-kind (semantic<->procedural) threshold.
# DEDUP_CANDIDATES=10
# DEDUP_CROSS_KIND_THRESHOLD=0.95
# Fuzzy forget: similarity floor and the no-op margin when two matches are close.
# FORGET_THRESHOLD=0.88
# FORGET_AMBIGUITY_MARGIN=0.03
# Skip the per-turn episodic trace for short messages / near-duplicate exchanges.
# EPISODIC_MIN_CHARS=12
# EPISODIC_DEDUP_THRESHOLD=0.97
# Consolidation ("sleep"): run every N turns (0 disables); episodic retention.
# CONSOLIDATE_EVERY_N_TURNS=20
# EPISODIC_MAX_AGE_DAYS=30
# Clock-driven sleep: a nightly maintenance pass (fold + consolidate) that runs
# without a user turn, so a quiet week still gets memory upkeep. Runs during
# quiet hours by design (it never pushes); once per local date, LLM step gated
# on new episodes. SLEEP_TIME is local wall-clock (HH:MM) in TIMEZONE.
# ENABLE_SLEEP=true
# SLEEP_TIME=03:30
# Hard per-kind note caps enforced during consolidation (JSON; 0 = uncapped).
# MAX_NOTES_PER_KIND={"semantic": 200, "procedural": 100, "episodic": 200}
# Half-life (days) for salience decay of never-recalled durable notes (0 disables).
# DURABLE_DECAY_HALF_LIFE_DAYS=180
# Working memory: summarize+trim history past this many messages (0 disables).
# WORKING_MEMORY_MAX_MESSAGES=40
# WORKING_MEMORY_KEEP_RECENT=12

# --- Time & calendar ---
# IANA timezone the assistant reasons in (e.g. Europe/Oslo). Unset => system-local.
# TIMEZONE=
# Inject current time + upcoming events into each turn.
# ENABLE_CALENDAR=true
# How far ahead (days) upcoming events are surfaced, and the per-turn cap.
# CALENDAR_UPCOMING_DAYS=14
# CALENDAR_MAX_EVENTS=20
# ICS subscription URLs mirrored (read-only) into the local calendar — Google's
# "secret iCal address" (Settings > your calendar > Integrate), Outlook, etc.
# JSON list. Synced events show up in the agenda, conflicts, and reminders, but
# must be changed in the source calendar.
# CALENDAR_ICS_URLS=["https://calendar.google.com/calendar/ical/…/basic.ics"]
# Minutes between pulls. 0 disables the loop (POST /calendar/sync still works).
# CALENDAR_SYNC_MINUTES=15

# --- Two-way CalDAV sync (opt-in; second switch for writes) ---
# OFF by default. When on, one writable CalDAV *collection* is pulled into the
# local calendar as read+WRITE rows (distinct from the read-only ICS mirror above).
# Point this at a calendar the assistant OWNS — do NOT overlap it with an ICS feed
# of the same events, or each event shows up twice.
# ENABLE_CALDAV=false
# Second, independent gate: push local create/reschedule/cancel back to the remote
# (undo maps a created event to a remote delete). Reads need only ENABLE_CALDAV.
# ENABLE_CALDAV_WRITE=false
# Which remote-calendar transport: "caldav" (Fastmail/iCloud/Nextcloud) or "google"
# (the Calendar REST API v3 — Google walls off CalDAV: v1 is dead, v2 returns 403).
# CALDAV_PROVIDER=caldav
# Google provider only: which calendar to sync ("primary", or a calendar id / email).
# GOOGLE_CALENDAR_ID=primary
# The writable calendar collection URL (https). Fastmail/iCloud/Nextcloud expose a
# per-calendar CalDAV URL; use that, not the principal/home URL.
# CALDAV_URL=https://caldav.fastmail.com/dav/calendars/user/you@example.com/abcd/
# Basic-auth credentials — an app-specific password, not your account password.
# CALDAV_USERNAME=you@example.com
# CALDAV_PASSWORD=
# Auth scheme: "password" (Basic, for Fastmail/iCloud/Nextcloud) or "oauth"
# (Bearer, for Google — which does not allow password CalDAV).
# CALDAV_AUTH=password
# Minutes between CalDAV pulls + outbox reconcile. 0 disables the loop.
# CALDAV_SYNC_MINUTES=15
#
# Google CalDAV (CALDAV_AUTH=oauth): create a Desktop-app OAuth client (Calendar API
# enabled, consent screen PUBLISHED so the token doesn't expire in 7 days), then mint
# a refresh token once with scripts/caldav_oauth_setup.py. For Google, CALDAV_URL is
# the primary calendar's events collection.
# CALDAV_URL=https://apps.google.com/calendar/dav/you@gmail.com/events/
# CALDAV_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# CALDAV_OAUTH_CLIENT_SECRET=GOCSPX-...
# CALDAV_OAUTH_REFRESH_TOKEN=1//...
# CALDAV_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token

# --- Voice notes (Telegram) ---
# Transcribe incoming Telegram voice messages locally (faster-whisper, offline
# after the first model download) and answer them like typed text.
# ENABLE_VOICE=true
# Whisper model size ("small" recommended for Norwegian + English).
# VOICE_MODEL=small
# Force a language code ("no", "en", …). Empty => autodetect per message.
# VOICE_LANGUAGE=
# Refuse clips longer than this many seconds.
# VOICE_MAX_SECONDS=600

# --- Slack channel ---
# Bot token (xoxb-…). Set => POST /slack/events accepts Events API callbacks.
# SLACK_BOT_TOKEN=
# Signing secret; every callback's HMAC is verified against it. Required with the token.
# SLACK_SIGNING_SECRET=
# App-level token (xapp-…) with connections:write. Set (with the bot token) =>
# events arrive over a Socket Mode websocket — no public HTTPS URL needed.
# SLACK_APP_TOKEN=
# Allowlist of Slack user ids the bot answers. EMPTY => it answers nobody
# (there is no pairing handshake, so this fails closed).
# SLACK_ALLOWED_USER_IDS=["U0123ABC"]
# Channel reminders and write-confirmations are pushed to. Unset => no push.
# SLACK_NOTIFY_CHANNEL=

# --- Email (opt-in; the only subsystem that talks to an external service) ---
# OFF by default. Nothing connects while this is false.
# ENABLE_EMAIL=false
# EMAIL_ADDRESS=you@gmail.com
# How to authenticate: oauth (XOAUTH2 refresh token) | password (app password).
# EMAIL_AUTH=oauth
# EMAIL_OAUTH_CLIENT_ID=
# EMAIL_OAUTH_CLIENT_SECRET=
# EMAIL_OAUTH_REFRESH_TOKEN=
# EMAIL_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
# App password, when EMAIL_AUTH=password.
# EMAIL_PASSWORD=
# IMAP/SMTP endpoints and the drafts mailbox (defaults are Gmail's).
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_DRAFTS_FOLDER=[Gmail]/Drafts
# EMAIL_MAX_MESSAGES=10
# Second, independent gate for actually SENDING. Drafting works without it; the
# assistant never sends in the background, only on an explicit request.
# ENABLE_EMAIL_SEND=false
# Minutes between background refreshes of the unread-mail snapshot injected
# into each turn (IMAP never runs on the reply path). 0 disables the block.
# EMAIL_SNAPSHOT_MINUTES=15
# Where archive_email moves mail on non-Gmail servers (Gmail archives by
# dropping the \Inbox label instead — the message stays in All Mail).
# EMAIL_ARCHIVE_FOLDER=Archive
# IMAP dialect: auto (sniff Gmail's X-GM-EXT-1 capability) | gmail | generic.
# EMAIL_PROVIDER=auto
# Max autonomous mailbox mutations (archive/label/mark-read/draft-reply) per
# background wake. 0 keeps the background strictly read-only. Sending is never
# possible in the background regardless.
# EMAIL_TRIAGE_MAX_ACTIONS=0

# --- Documents / notes ---
# Ingest documents and surface relevant chunks into recall each turn.
# ENABLE_DOCS=true
# How many chunks to inject per turn, and the cosine floor to inject at all.
# DOCS_RECALL_TOP_K=3
# DOCS_MIN_SIMILARITY=0.35
# Target chunk size (characters) at ingest time. Must be at least 1.
# DOCS_CHUNK_CHARS=800
# Allow POST /documents to ingest a URL (fetched server-side). Off by default:
# on a reachable server this is an SSRF primitive. Uploads (PDF/DOCX/text via
# POST /documents/upload) are always available while docs are enabled.
# ENABLE_DOCS_URL_INGEST=false
# Section size (characters) when summarizing a long document. A document larger
# than this is summarized section by section, then folded into one summary.
# DOCS_SUMMARIZE_CHARS=8000

# --- Tasks / to-dos ---
# Inject the open to-do list into each turn (read path).
# ENABLE_TASKS=true
# Cap on how many open tasks are injected per turn.
# TASKS_MAX_OPEN=20

# --- People / contacts (lightweight CRM) ---
# Keep a store of people the user knows (relationship, keep-in-touch cadence,
# last contact, birthday, notes), inject a compact roster each turn with anyone
# overdue for contact / with a birthday soon flagged first, and expose the people
# tools. Off by default. Birthdays within PEOPLE_BIRTHDAY_LEAD_DAYS also fire a
# proactive reminder (needs ENABLE_REMINDERS) and appear in the briefing.
# ENABLE_PEOPLE=false
# Cap on how many people are injected per turn.
# PEOPLE_MAX_OPEN=20
# A birthday within this many days is flagged and triggers a heads-up reminder.
# PEOPLE_BIRTHDAY_LEAD_DAYS=7

# --- Health / habits log ---
# Keep an append log of habits / health metrics (workouts, sleep, weight,
# steps…) and expose the habit tools (log + summarize streaks/trends). Off by
# default. Tool-only — not injected into every turn.
# ENABLE_HABITS=false

# --- Subscriptions / bills ---
# Track recurring charges (amount, cadence, renewal date), expose the
# subscription tools, and fire a renewal reminder before each charge. Off by
# default. Needs ENABLE_REMINDERS for the renewal heads-up to be pushed.
# ENABLE_SUBSCRIPTIONS=false
# Fire a renewal reminder this many days before a subscription renews.
# SUBSCRIPTIONS_RENEWAL_LEAD_DAYS=3

# --- Reading list (read-it-later) ---
# Keep a list of links to read later and expose the reading tools (save_reading,
# list_reading, mark_read, remove_reading). Off by default. Tool-only — not
# injected into every turn; the model lists it on request.
# ENABLE_READING=false
# Cap on how many unread items list_reading returns per call.
# READING_MAX_OPEN=50

# --- Weather ---
# Fetch a short forecast off the reply path (Open-Meteo, keyless) and inject it
# into each turn's context and the daily briefing; also unlocks the get_weather
# tool for any city. Off by default (needs a location, makes an outbound call).
# ENABLE_WEATHER=false
# The location, as decimal degrees. Optional: if unset but WEATHER_LOCATION_NAME
# is given, the name is geocoded and cached. Explicit coordinates take precedence.
# WEATHER_LATITUDE=59.91
# WEATHER_LONGITUDE=10.75
# A place name ("Oslo"): the block's label, and — with no coordinates — geocoded.
# WEATHER_LOCATION_NAME=Oslo
# "metric" (°C, km/h) or "imperial" (°F, mph).
# WEATHER_UNITS=metric
# Minutes between background forecast refreshes. 0 disables the block.
# WEATHER_REFRESH_MINUTES=60

# --- Proactive reminders ---
# Push a nudge ahead of upcoming events ("Dentist in 1 hour"). Off => no reminders.
# ENABLE_REMINDERS=true
# Minutes before an event to fire. JSON list; several leads => several nudges
# (e.g. [1440, 60] = a day before and an hour before). Default nudges an hour out
# and again 15 minutes out.
# REMINDER_LEAD_MINUTES=[60, 15]
# ntfy topic URL / generic webhook the reminder is POSTed to. Unset => reminders are
# computed and returned by POST /reminders/run but not pushed anywhere.
# REMINDER_WEBHOOK_URL=https://ntfy.sh/your-private-topic
# How often the built-in ticker fires (seconds). 0 disables it (drive POST
# /reminders/run from external cron instead).
# REMINDER_TICK_SECONDS=60
# >0 => re-nudge every N minutes from the lead window until the event starts,
# instead of firing each lead once. Dated tasks also nag past their due time
# ("Task overdue: … (30 min ago)") until done. 0 keeps the one-shot behavior.
# REMINDER_REPEAT_MINUTES=15
# How long past its due time an overdue task keeps nagging (minutes). Only used
# when REMINDER_REPEAT_MINUTES > 0.
# REMINDER_OVERDUE_MAX_MINUTES=1440

# --- Daily briefing ---
# Push one digest per day (agenda + due tasks + unread mail when email is on)
# through the same channels reminders use. POST /briefing/run sends it on demand.
# ENABLE_BRIEFING=true
# Local wall-clock time (HH:MM, in TIMEZONE) the briefing becomes due; it fires
# on the first tick at/after this, exactly once per day. With ENABLE_HEARTBEAT
# the model composes it in its own voice; without it the digest goes verbatim.
# BRIEFING_TIME=07:30

# --- Heartbeat (deliberative proactivity) ---
# Periodically let the assistant itself review the situation (due follow-ups,
# inbox changes, contact staleness — or nothing at all) and decide whether to
# reach out — or stay silent. Every wake outside quiet hours is a model call,
# so HEARTBEAT_MINUTES is the token-cost dial. Also unlocks the
# schedule_followup tools. Off by default (fail-safe); turning it on —
# together with ENABLE_BRIEFING — is the recommended setup for a personal
# deploy: it is what makes the assistant reach out like a human one would.
# ENABLE_HEARTBEAT=false
# Minutes between wakes (0 disables the ticker; POST /heartbeat/run still works).
# HEARTBEAT_MINUTES=30
# Minimum minutes between ambient *pushes* (no due follow-up or briefing
# behind them) — bounds delivery, never the model's judgment; scheduled
# intent always delivers.
# HEARTBEAT_MIN_GAP_MINUTES=120
# Hours of user silence before "we haven't talked in a while" becomes a
# trigger. 0 disables the staleness trigger; 24 is the "feels like an
# assistant" setting — one gentle check-in after a day of silence, and only
# when it has something genuinely useful to say.
# HEARTBEAT_CONTACT_GAP_HOURS=24
# Self-pacing: the assistant can set its own next wake (the set_next_wake tool),
# and the scheduler never sleeps past the soonest open follow-up, so it can wake
# right before a meeting. These clamp how far a self-set wake may move from
# HEARTBEAT_MINUTES. WAKE_MAX=0 means "never later than the fixed cadence" (the
# model may only pull the next wake earlier); raise it (e.g. 360) to let the
# assistant back off and save tokens on quiet days.
# HEARTBEAT_WAKE_MIN_MINUTES=5
# HEARTBEAT_WAKE_MAX_MINUTES=0

# --- Telegram channel ---
# Create a bot with @BotFather (/newbot) and paste its token to enable the channel.
# The first chat to message an unpaired bot is asked to echo back a pairing code
# printed in the server log; once paired it becomes the owner and every other chat
# is ignored. Un-pair by deleting memory/telegram_chats.json.
# TELEGRAM_BOT_TOKEN=
# Optional: pin/add chats explicitly (JSON list of ids), merged with the paired set.
# TELEGRAM_ALLOWED_CHAT_IDS=[123456789]
# Merge consecutive plain-text messages from the same chat (typically sent while
# a reply was still being composed) into one turn — a thought split across
# several quick messages gets one considered answer instead of fragments.
# TELEGRAM_COALESCE_MESSAGES=true
